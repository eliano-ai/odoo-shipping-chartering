<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_cost_allocation_rule_list" model="ir.ui.view">
        <field name="name">vessel.cost.allocation.rule.list</field>
        <field name="model">vessel.cost.allocation.rule</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="cost_category_id"/>
                <field name="allocation_method"/>
                <field name="fixed_percentage_value" invisible="allocation_method != 'fixed_percentage'"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_cost_allocation_rule_form" model="ir.ui.view">
        <field name="name">vessel.cost.allocation.rule.form</field>
        <field name="model">vessel.cost.allocation.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="cost_category_id"/>
                        <field name="allocation_method"/>
                        <field name="fixed_percentage_value" invisible="allocation_method != 'fixed_percentage'"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vessel_cost_allocation_rule" model="ir.actions.act_window">
        <field name="name">Aturan Alokasi Biaya</field>
        <field name="res_model">vessel.cost.allocation.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
