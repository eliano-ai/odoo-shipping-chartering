<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_cargo_type_view_list" model="ir.ui.view">
        <field name="name">vessel.cargo.type.list</field>
        <field name="model">vessel.cargo.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Kargo" editable="bottom">
                <field name="name"/>
                <field name="is_dangerous"/>
                <field name="default_stowage_factor"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="vessel_cargo_type_view_form" model="ir.ui.view">
        <field name="name">vessel.cargo.type.form</field>
        <field name="model">vessel.cargo.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Kargo">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="is_dangerous"/>
                        <field name="default_stowage_factor"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vessel_cargo_type" model="ir.actions.act_window">
        <field name="name">Tipe Kargo</field>
        <field name="res_model">vessel.cargo.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada tipe kargo</p>
            <p>Buat master tipe kargo — batubara, nikel, general cargo, dll.</p>
        </field>
    </record>

</odoo>
