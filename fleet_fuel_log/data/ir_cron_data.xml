<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_actions_server_fleet_fuel_anomaly" model="ir.actions.server">
        <field name="name">Fleet Fuel: Check Anomalies Action</field>
        <field name="model_id" ref="model_fleet_fuel_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_anomalies()</field>
    </record>

    <record id="cron_fleet_fuel_anomaly_check" model="ir.cron">
        <field name="name">Fleet Fuel: Check &amp; Notify Anomalies</field>
        <field name="ir_actions_server_id" ref="ir_actions_server_fleet_fuel_anomaly"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="nextcall" eval="(DateTime.now()).replace(hour=6, minute=0, second=0)"/>
        <field name="priority">10</field>
    </record>
</odoo>