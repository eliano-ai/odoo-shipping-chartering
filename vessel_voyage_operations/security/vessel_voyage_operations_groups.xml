<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_voyage_ops_portal" model="res.groups">
        <field name="name">Voyage Ops Portal (Nakhoda)</field>
    </record>

    <record id="group_voyage_ops_user" model="res.groups">
        <field name="name">Voyage Ops Operations</field>
        <field name="implied_ids" eval="[(4, ref('fleet.fleet_group_user'))]"/>
    </record>

    <record id="group_voyage_ops_manager" model="res.groups">
        <field name="name">Voyage Ops Manager</field>
        <field name="implied_ids" eval="[(4, ref('vessel_voyage_operations.group_voyage_ops_user')), (4, ref('fleet.fleet_group_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
