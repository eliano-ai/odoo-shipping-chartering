<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_view_form_port_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.port.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_port"/>
                <field name="unlocode" invisible="not is_port"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_view_list_port" model="ir.ui.view">
        <field name="name">res.partner.list.port</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Pelabuhan">
                <field name="name"/>
                <field name="unlocode"/>
                <field name="country_id"/>
                <field name="phone" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_res_partner_port" model="ir.actions.act_window">
        <field name="name">Pelabuhan</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="res_partner_view_list_port"/>
        <field name="domain">[('is_port', '=', True)]</field>
        <field name="context">{'default_is_port': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada pelabuhan</p>
            <p>Tandai partner sebagai "Adalah Pelabuhan" untuk dipakai sebagai load/discharge port di kontrak charter.</p>
        </field>
    </record>

</odoo>
