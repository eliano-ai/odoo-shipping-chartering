<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Keputusan Sprint 15 (final-check Sprint 21): Voyage P&L masuk app Maritime,
         sejajar Chartering & Voyage Operations — bukan Fleet, karena secara IA modul
         ini adalah lapisan finansial komersial (payoff analytic plans), bukan asset
         management fisik. Konsisten dengan restrukturisasi Maritime sebelumnya. -->
    <menuitem id="menu_voyage_pnl_root" name="Voyage P&amp;L"
              parent="maritime.menu_maritime_root" sequence="30"/>

    <menuitem id="menu_voyage_pnl_list_root" name="Voyage P&amp;L"
              parent="menu_voyage_pnl_root" sequence="10"/>

    <menuitem id="menu_vessel_voyage_pnl_all" name="Semua Voyage P&amp;L"
              parent="menu_voyage_pnl_list_root" action="action_vessel_voyage_pnl"
              sequence="10"/>

    <menuitem id="menu_vessel_pnl_bulk_generate" name="Generate P&amp;L Massal"
              parent="menu_voyage_pnl_list_root" action="action_vessel_pnl_bulk_generate_wizard"
              sequence="20" groups="vessel_voyage_pnl.group_voyage_pnl_finance,vessel_voyage_pnl.group_voyage_pnl_manager"/>

    <menuitem id="menu_vessel_pnl_root" name="Vessel P&amp;L"
              parent="menu_voyage_pnl_root" sequence="20"/>

    <menuitem id="menu_vessel_vessel_pnl_all" name="P&amp;L Bulanan per Kapal"
              parent="menu_vessel_pnl_root" action="action_vessel_vessel_pnl"
              sequence="10"/>

    <menuitem id="menu_vessel_vessel_pnl_trend" name="Utilisasi &amp; TCE Trend"
              parent="menu_vessel_pnl_root" action="action_vessel_vessel_pnl_trend"
              sequence="20"/>

    <!-- §10.9 acceptance criteria: group_voyage_pnl_user TIDAK boleh lihat menu Budget
         sama sekali — eksplisit groups (bukan cuma andalkan access CSV) supaya menu
         benar-benar tersembunyi, bukan error saat diklik. -->
    <menuitem id="menu_vessel_budget_root" name="Budget"
              parent="menu_voyage_pnl_root" sequence="25"
              groups="vessel_voyage_pnl.group_voyage_pnl_finance,vessel_voyage_pnl.group_voyage_pnl_manager,vessel_voyage_pnl.group_voyage_pnl_director"/>

    <menuitem id="menu_vessel_vessel_budget_all" name="Budget per Kapal"
              parent="menu_vessel_budget_root" action="action_vessel_vessel_budget"
              sequence="10"/>

    <menuitem id="menu_vessel_vessel_budget_line_pivot" name="Realisasi vs Budget"
              parent="menu_vessel_budget_root" action="action_vessel_vessel_budget_line_pivot"
              sequence="20"/>

    <menuitem id="menu_voyage_pnl_config" name="Konfigurasi"
              parent="menu_voyage_pnl_root" sequence="90"
              groups="vessel_voyage_pnl.group_voyage_pnl_manager"/>

    <menuitem id="menu_vessel_pnl_cost_category" name="Kategori Biaya P&amp;L"
              parent="menu_voyage_pnl_config" action="action_vessel_pnl_cost_category"
              sequence="10"/>

    <menuitem id="menu_vessel_cost_allocation_rule" name="Aturan Alokasi Biaya"
              parent="menu_voyage_pnl_config" action="action_vessel_cost_allocation_rule"
              sequence="20"/>

</odoo>
