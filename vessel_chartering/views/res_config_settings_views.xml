<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_chartering" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.vessel.chartering</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="after">
                <block title="Vessel Chartering" id="vessel_chartering_setting">
                    <setting id="despatch_as_credit_note_setting"
                             string="Despatch sebagai Credit Note"
                             help="Jika aktif, despatch dibuat sebagai credit note terpisah. Jika tidak, despatch dibuat sebagai invoice line bernilai negatif.">
                        <field name="despatch_as_credit_note"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
