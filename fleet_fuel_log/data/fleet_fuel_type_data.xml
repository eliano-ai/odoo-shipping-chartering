<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Data master jenis BBM sesuai kebutuhan maritim -->

    <record id="fuel_type_hsd" model="fleet.fuel.type">
        <field name="name">Solar / HSD (High Speed Diesel)</field>
        <field name="code">HSD</field>
        <field name="default_price">15000.0</field>
        <field name="anomaly_threshold_pct">30.0</field>
        <field name="sequence">10</field>
    </record>

    <record id="fuel_type_mfo" model="fleet.fuel.type">
        <field name="name">Marine Fuel Oil (MFO)</field>
        <field name="code">MFO</field>
        <field name="default_price">12000.0</field>
        <field name="anomaly_threshold_pct">25.0</field>
        <field name="sequence">20</field>
    </record>

    <record id="fuel_type_mgo" model="fleet.fuel.type">
        <field name="name">Marine Gas Oil (MGO)</field>
        <field name="code">MGO</field>
        <field name="default_price">18000.0</field>
        <field name="anomaly_threshold_pct">30.0</field>
        <field name="sequence">30</field>
    </record>

</odoo>
