<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fleet_vehicle_form_inherit_chartering" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.chartering</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[1]" position="before">
                <page string="Chartering" name="chartering" invisible="not is_vessel">
                    <group>
                        <field name="analytic_account_id" readonly="1"/>
                        <field name="charter_status" readonly="1"/>
                        <field name="active_charter_id" readonly="1"/>
                    </group>
                    <field name="charter_contract_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="contract_type"/>
                            <field name="direction"/>
                            <field name="partner_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
