<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for fleet.maintenance.schedule reference -->
    <record id="seq_fleet_maintenance_schedule" model="ir.sequence">
        <field name="name">Fleet Maintenance Schedule</field>
        <field name="code">fleet.maintenance.schedule</field>
        <field name="prefix">FMS/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
