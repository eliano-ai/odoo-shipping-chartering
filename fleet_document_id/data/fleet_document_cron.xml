<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_fleet_doc_expiry_check" model="ir.cron">
        <field name="name">Fleet: Cek Expired Dokumen Kendaraan Harian</field>
        <field name="model_id" ref="model_fleet_vehicle_document"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_expiry_and_notify()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=0, minute=0, second=0)"/>
        <field name="priority">5</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>