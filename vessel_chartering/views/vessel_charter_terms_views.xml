<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_charter_terms_view_list" model="ir.ui.view">
        <field name="name">vessel.charter.terms.list</field>
        <field name="model">vessel.charter.terms</field>
        <field name="arch" type="xml">
            <list string="Charter Terms">
                <field name="name"/>
                <field name="loading_terms"/>
                <field name="sundays_holidays_included" string="SHINC"/>
                <field name="laytime_reversible_default" string="Reversible"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="vessel_charter_terms_view_form" model="ir.ui.view">
        <field name="name">vessel.charter.terms.form</field>
        <field name="model">vessel.charter.terms</field>
        <field name="arch" type="xml">
            <form string="Charter Terms">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="loading_terms"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="sundays_holidays_included"/>
                            <field name="laytime_reversible_default"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Catatan tambahan mengenai terms ini..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vessel_charter_terms" model="ir.actions.act_window">
        <field name="name">Charter Terms</field>
        <field name="res_model">vessel.charter.terms</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada template charter terms</p>
            <p>Buat template terms yang sering dipakai, misal "FIOST 8,000/8,000 SHINC".</p>
        </field>
    </record>

</odoo>
