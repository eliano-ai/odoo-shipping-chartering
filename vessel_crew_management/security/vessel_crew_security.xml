<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_groups_privilege_vessel_crew" model="res.groups.privilege">
        <field name="name">Vessel Crew Management</field>
        <field name="sequence">25</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
    </record>

    <record id="group_vessel_crew_user" model="res.groups">
        <field name="name">Crew User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_vessel_crew"/>
    </record>

    <record id="group_vessel_crew_manager" model="res.groups">
        <field name="name">Crew Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_vessel_crew"/>
        <field name="implied_ids" eval="[(4, ref('group_vessel_crew_user'))]"/>
    </record>
</odoo>
