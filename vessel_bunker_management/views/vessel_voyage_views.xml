<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_voyage_view_form_inherit_bunker_management" model="ir.ui.view">
        <field name="name">vessel.voyage.form.inherit.bunker.management</field>
        <field name="model">vessel.voyage</field>
        <field name="inherit_id" ref="vessel_voyage_operations.vessel_voyage_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_rob_reconciliations" type="object"
                        class="oe_stat_button" icon="fa-tint"
                        invisible="rob_anomaly_count == 0">
                    <field name="rob_anomaly_count" widget="statinfo" string="ROB Anomalies"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
