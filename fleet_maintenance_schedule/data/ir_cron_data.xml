<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ================================================================
             CRON: Daily Maintenance Reminder Email
        ================================================================ -->
        <record id="cron_fleet_maintenance_reminder" model="ir.cron">
            <field name="name">Fleet: Send Maintenance Schedule Reminders</field>
            <field name="model_id" ref="model_fleet_maintenance_schedule"/>
            <field name="code">model._cron_send_maintenance_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <!-- Run at 07:00 server time -->
            <field name="nextcall" eval="(DateTime.now()).replace(hour=7, minute=0, second=0)"/>
            <field name="priority">10</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>