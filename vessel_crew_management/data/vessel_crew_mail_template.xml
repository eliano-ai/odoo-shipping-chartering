<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="email_template_crew_schedule" model="mail.template">
        <field name="name">Vessel Crew: Jadwal Sign On</field>
        <field name="model_id" ref="vessel_crew_management.model_vessel_crew_assignment"/>
        <field name="subject">Jadwal Penugasan Kapal — {{object.vehicle_id.name}} · Sign On {{object.sign_on_date}}</field>
        <field name="email_to">{{object.seafarer_id.work_email or object.seafarer_id.employee_id.work_email}}</field>
        <field name="auto_delete">True</field>
        <field name="body_html"><![CDATA[
<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:24px;">
  <div style="background:#0F6E56;color:#fff;padding:20px 24px;border-radius:8px 8px 0 0;">
    <h2 style="margin:0;font-size:20px;">Jadwal Penugasan Kapal</h2>
    <p style="margin:4px 0 0;opacity:.8;font-size:14px;">{{object.company_id.name}}</p>
  </div>
  <div style="background:#fff;border:1px solid #e5e7eb;border-top:none;padding:24px;border-radius:0 0 8px 8px;">
    <p>Yth. <b>{{object.seafarer_id.name}}</b>,</p>
    <p>Anda telah dijadwalkan untuk bertugas dengan detail sebagai berikut:</p>
    <table style="width:100%;border-collapse:collapse;margin:16px 0;">
      <tr style="background:#F9FAFB;">
        <td style="padding:10px 12px;border:1px solid #e5e7eb;font-weight:bold;width:40%;">Kapal</td>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;">{{object.vehicle_id.name}}</td>
      </tr>
      <tr>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;font-weight:bold;">Jabatan</td>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;">{{object.rank_id.name}}</td>
      </tr>
      <tr style="background:#F9FAFB;">
        <td style="padding:10px 12px;border:1px solid #e5e7eb;font-weight:bold;">Tanggal Sign On</td>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;color:#0F6E56;font-weight:bold;">{{object.sign_on_date}}</td>
      </tr>
      <tr>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;font-weight:bold;">Pelabuhan Sign On</td>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;">{{object.sign_on_port or '-'}}</td>
      </tr>
      <tr style="background:#F9FAFB;">
        <td style="padding:10px 12px;border:1px solid #e5e7eb;font-weight:bold;">Estimasi Sign Off</td>
        <td style="padding:10px 12px;border:1px solid #e5e7eb;">{{object.sign_off_date or '-'}}</td>
      </tr>
    </table>
    % if object.cert_warning_details:
    <div style="background:#FEF3C7;border-left:4px solid #F59E0B;padding:12px;margin:16px 0;border-radius:4px;">
      <b>⚠ Peringatan Sertifikat:</b><br/>
      <pre style="margin:8px 0 0;font-size:13px;">{{object.cert_warning_details}}</pre>
    </div>
    % endif
    <p style="color:#6B7280;font-size:13px;">
      Mohon konfirmasikan kehadiran Anda dengan membalas email ini atau menghubungi bagian operasional.
    </p>
    <p style="color:#6B7280;font-size:12px;border-top:1px solid #e5e7eb;padding-top:16px;margin-top:24px;">
      Email ini dikirim otomatis oleh sistem.<br/>{{object.company_id.name}}
    </p>
  </div>
</div>
        ]]></field>
    </record>
</odoo>
