<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="vessel_crew_rank_view_list" model="ir.ui.view">
    <field name="name">vessel.crew.rank.list</field>
    <field name="model">vessel.crew.rank</field>
    <field name="arch" type="xml">
      <list string="Jabatan ABK" editable="bottom">
        <field name="sequence" widget="handle"/>
        <field name="name"/>
        <field name="code"/>
        <field name="department"/>
        <field name="is_officer"/>
        <field name="is_watchkeeper"/>
        <field name="required_coc_grade"/>
        <field name="seafarer_count"/>
      </list>
    </field>
  </record>
  <record id="action_vessel_crew_rank" model="ir.actions.act_window">
    <field name="name">Master Jabatan ABK</field>
    <field name="res_model">vessel.crew.rank</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
