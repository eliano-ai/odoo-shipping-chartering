<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Config Form View -->
    <record id="view_shopify_config_form" model="ir.ui.view">
        <field name="name">shopify.config.form</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <form string="Shopify Store Configuration">
                <header>
                    <button name="action_test_connection" string="Test Connection"
                            type="object" class="btn-primary"/>
                    <button name="action_register_webhooks" string="Register Webhooks"
                            type="object" class="btn-secondary"/>
                    <button name="action_open_bulk_sync_wizard" string="Bulk Sync"
                            type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Nustik HK Store"/></h1>
                    </div>
                    <group>
                        <group string="Connection">
                            <field name="shop_url" placeholder="storename.myshopify.com"/>
                            <field name="api_version"/>
                            <field name="access_token" password="True"/>
                            <field name="webhook_secret" password="True"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Defaults">
                            <field name="company_id"/>
                            <field name="default_warehouse_id"
                                   domain="[('company_id', '=', company_id)]"/>
                            <field name="default_pricelist_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sync Settings">
                            <group string="Sync Toggles">
                                <field name="sync_product"/>
                                <field name="sync_inventory"/>
                                <field name="sync_order"/>
                            </group>
                            <group string="Order Behavior">
                                <field name="so_auto_confirm"/>
                                <field name="missing_sku_mode"/>
                                <field name="default_shipping_product_id"/>
                                <field name="default_discount_product_id"/>
                                <field name="default_guest_partner_id"/>
                            </group>
                            <group string="Last Sync Timestamps">
                                <field name="last_order_sync" readonly="1"/>
                                <field name="last_inventory_sync" readonly="1"/>
                                <field name="last_product_sync" readonly="1"/>
                            </group>
                        </page>
                        <page string="Location Mapping">
                            <field name="location_mapping_ids">
                                <list editable="bottom">
                                    <field name="warehouse_id"/>
                                    <field name="shopify_location_id"/>
                                    <field name="shopify_location_name"/>
                                    <field name="is_primary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tax Mapping">
                            <field name="tax_mapping_ids">
                                <list editable="bottom">
                                    <field name="shopify_tax_title"/>
                                    <field name="shopify_tax_rate"/>
                                    <field name="tax_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Pricelist Mapping">
                            <field name="pricelist_mapping_ids">
                                <list editable="bottom">
                                    <field name="shopify_currency"/>
                                    <field name="pricelist_id"/>
                                    <field name="shopify_market_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Config List View -->
    <record id="view_shopify_config_tree" model="ir.ui.view">
        <field name="name">shopify.config.list</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <list string="Shopify Stores">
                <field name="name"/>
                <field name="shop_url"/>
                <field name="company_id"/>
                <field name="api_version"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="last_order_sync"/>
            </list>
        </field>
    </record>

    <!-- Config Action -->
    <record id="action_shopify_config" model="ir.actions.act_window">
        <field name="name">Shopify Stores</field>
        <field name="res_model">shopify.config</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>