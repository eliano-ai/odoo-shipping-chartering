<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_vessel_budget_list" model="ir.ui.view">
        <field name="name">vessel.vessel.budget.list</field>
        <field name="model">vessel.vessel.budget</field>
        <field name="arch" type="xml">
            <list>
                <field name="vessel_id"/>
                <field name="year" options="{'enable_formatting': False}"/>
                <field name="total_budget_cost" sum="Total Budget"/>
                <field name="total_actual_cost" sum="Total Realisasi"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_vessel_budget_form" model="ir.ui.view">
        <field name="name">vessel.vessel.budget.form</field>
        <field name="model">vessel.vessel.budget</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_reset_draft" type="object" string="Reset ke Draft"
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="vessel_id" readonly="state != 'draft'"/>
                            <field name="year" readonly="state != 'draft'" options="{'enable_formatting': False}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="total_budget_cost"/>
                            <field name="total_actual_cost"/>
                        </group>
                    </group>
                    <field name="budget_line_ids" context="{'default_budget_id': id}">
                        <list editable="bottom">
                            <field name="month"/>
                            <field name="cost_category_id"/>
                            <field name="planned_amount"/>
                            <field name="actual_amount" readonly="1"/>
                            <field name="variance_amount" readonly="1"/>
                            <field name="variance_pct" readonly="1"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vessel_vessel_budget_line_pivot" model="ir.ui.view">
        <field name="name">vessel.vessel.budget.line.pivot</field>
        <field name="model">vessel.vessel.budget.line</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="budget_id" type="row"/>
                <field name="cost_category_id" type="row"/>
                <field name="month" type="col"/>
                <field name="planned_amount" type="measure"/>
                <field name="actual_amount" type="measure"/>
                <field name="variance_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_vessel_vessel_budget" model="ir.actions.act_window">
        <field name="name">Budget per Kapal</field>
        <field name="res_model">vessel.vessel.budget</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_vessel_vessel_budget_line_pivot" model="ir.actions.act_window">
        <field name="name">Realisasi vs Budget</field>
        <field name="res_model">vessel.vessel.budget.line</field>
        <field name="view_mode">pivot</field>
    </record>

</odoo>
