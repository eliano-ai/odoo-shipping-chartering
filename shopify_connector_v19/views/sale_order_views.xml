<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_shopify_info" model="ir.ui.view">
        <field name="name">sale.order.form.shopify</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Shopify" invisible="not shopify_order_id">
                    <group string="Shopify Order Info">
                        <group>
                            <field name="shopify_order_id" readonly="1"/>
                            <field name="shopify_financial_status" readonly="1"/>
                            <field name="shopify_payment_gateway" readonly="1"/>
                        </group>
                        <group>
                            <field name="shopify_amount_paid" readonly="1"/>
                            <field name="shopify_sync_status" readonly="1"
                                   widget="badge"
                                   decoration-success="shopify_sync_status == 'synced'"
                                   decoration-danger="shopify_sync_status == 'error'"
                                   decoration-warning="shopify_sync_status == 'needs_review'"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>