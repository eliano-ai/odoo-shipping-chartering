<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_voyage_pnl_user" model="res.groups">
        <field name="name">Voyage P&amp;L User (Operations/Chartering)</field>
        <field name="implied_ids" eval="[(4, ref('fleet.fleet_group_user'))]"/>
    </record>

    <record id="group_voyage_pnl_finance" model="res.groups">
        <field name="name">Voyage P&amp;L Finance</field>
        <field name="implied_ids" eval="[(4, ref('vessel_voyage_pnl.group_voyage_pnl_user'))]"/>
    </record>

    <record id="group_voyage_pnl_manager" model="res.groups">
        <field name="name">Voyage P&amp;L Manager</field>
        <field name="implied_ids" eval="[(4, ref('vessel_voyage_pnl.group_voyage_pnl_finance')), (4, ref('fleet.fleet_group_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_voyage_pnl_director" model="res.groups">
        <field name="name">Voyage P&amp;L Direksi (Read-Only)</field>
    </record>

</odoo>
