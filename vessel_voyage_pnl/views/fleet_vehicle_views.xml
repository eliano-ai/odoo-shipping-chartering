<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fleet_vehicle_form_inherit_voyage_pnl" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.voyage.pnl</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Voyage P&amp;L" name="voyage_pnl" invisible="not is_vessel">
                    <group>
                        <field name="budget_variance_threshold_pct"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
