<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_fleet_fuel_root"
        name="Fuel"
        parent="fleet.menu_root"
        sequence="20"
        groups="fleet_fuel_log.group_fleet_manager,fleet_fuel_log.group_driver"
    />

    <menuitem id="menu_fleet_fuel_log_all"
        name="Fuel Logs"
        parent="menu_fleet_fuel_root"
        action="action_fleet_fuel_log"
        sequence="10"
    />

    <record id="action_fleet_fuel_log_to_approve" model="ir.actions.act_window">
        <field name="name">Pending Approval</field>
        <field name="res_model">fleet.fuel.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','to_approve')]</field>
        <field name="context">{'search_default_to_approve': 1}</field>
    </record>

    <menuitem id="menu_fleet_fuel_log_approve"
        name="Pending Approval"
        parent="menu_fleet_fuel_root"
        action="action_fleet_fuel_log_to_approve"
        sequence="20"
        groups="fleet_fuel_log.group_fleet_manager"
    />

    <menuitem id="menu_fleet_vehicle_trip"
        name="Trips / Voyages"
        parent="menu_fleet_fuel_root"
        action="action_fleet_vehicle_trip"
        sequence="30"
    />

    <menuitem id="menu_fleet_fuel_type"
        name="Fuel Types"
        parent="menu_fleet_fuel_root"
        action="action_fleet_fuel_type"
        sequence="90"
        groups="fleet_fuel_log.group_fleet_manager"
    />

    <record id="action_fleet_fuel_log_my" model="ir.actions.act_window">
        <field name="name">My Fuel Logs</field>
        <field name="res_model">fleet.fuel.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('logged_by','=',uid)]</field>
    </record>

    <menuitem id="menu_fleet_fuel_log_my"
        name="My Logs"
        parent="menu_fleet_fuel_root"
        action="action_fleet_fuel_log_my"
        sequence="15"
        groups="fleet_fuel_log.group_driver"
    />

</odoo>