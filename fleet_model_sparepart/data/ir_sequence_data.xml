<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Sequence opsional untuk auto part number.
        Aktifkan di model jika dibutuhkan dengan:
            self.env['ir.sequence'].next_by_code('fleet.model.sparepart')
    -->
    <record id="seq_fleet_model_sparepart" model="ir.sequence">
        <field name="name">Fleet Model Sparepart</field>
        <field name="code">fleet.model.sparepart</field>
        <field name="prefix">PART/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
