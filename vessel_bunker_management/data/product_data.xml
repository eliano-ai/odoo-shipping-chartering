<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Produk generik untuk baris PO bunker (tahap inquiry/quote pakai kategori FO/DO
         tetap sesuai desain tech spec §3.2-3.3 — beda dari tahap BDN/delivery yang
         pakai fleet.fuel.type fleksibel, lihat vessel.bunker.delivery Sprint 24). -->
    <record id="product_bunker_fo" model="product.product">
        <field name="name">Bunker Fuel Oil (FO)</field>
        <field name="type">consu</field>
        <field name="purchase_ok">True</field>
        <field name="sale_ok">False</field>
        <field name="uom_id" ref="uom.product_uom_ton"/>
    </record>

    <record id="product_bunker_do" model="product.product">
        <field name="name">Bunker Diesel Oil (DO)</field>
        <field name="type">consu</field>
        <field name="purchase_ok">True</field>
        <field name="sale_ok">False</field>
        <field name="uom_id" ref="uom.product_uom_ton"/>
    </record>

    <record id="product_bunker_barging_fee" model="product.product">
        <field name="name">Bunker Barging Fee</field>
        <field name="type">service</field>
        <field name="purchase_ok">True</field>
        <field name="sale_ok">False</field>
    </record>

</odoo>
