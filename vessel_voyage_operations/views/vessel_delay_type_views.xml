<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_delay_type_view_list" model="ir.ui.view">
        <field name="name">vessel.delay.type.list</field>
        <field name="model">vessel.delay.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Delay" editable="bottom">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="vessel_delay_type_view_form" model="ir.ui.view">
        <field name="name">vessel.delay.type.form</field>
        <field name="model">vessel.delay.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Delay">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vessel_delay_type" model="ir.actions.act_window">
        <field name="name">Tipe Delay</field>
        <field name="res_model">vessel.delay.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada tipe delay</p>
            <p>Buat master tipe delay/event voyage — weather, port congestion, breakdown, dll.</p>
        </field>
    </record>

</odoo>
