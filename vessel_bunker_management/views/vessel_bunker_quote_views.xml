<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_bunker_quote_list" model="ir.ui.view">
        <field name="name">vessel.bunker.quote.list</field>
        <field name="model">vessel.bunker.quote</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="inquiry_id"/>
                <field name="supplier_id"/>
                <field name="price_fo_usd_mt"/>
                <field name="price_do_usd_mt"/>
                <field name="total_estimated_usd"/>
                <field name="price_vs_market_pct" widget="percentage"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_bunker_quote_search" model="ir.ui.view">
        <field name="name">vessel.bunker.quote.search</field>
        <field name="model">vessel.bunker.quote</field>
        <field name="arch" type="xml">
            <search>
                <field name="inquiry_id"/>
                <field name="supplier_id"/>
                <group>
                    <filter string="Inquiry" name="group_inquiry" context="{'group_by': 'inquiry_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vessel_bunker_quote_comparison" model="ir.actions.act_window">
        <field name="name">Perbandingan Quote</field>
        <field name="res_model">vessel.bunker.quote</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_vessel_bunker_quote_search"/>
        <field name="context">{'search_default_group_inquiry': 1}</field>
    </record>

</odoo>
