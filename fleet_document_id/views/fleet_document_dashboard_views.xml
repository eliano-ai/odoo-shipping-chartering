<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard: ringkasan compliance semua kendaraan -->
    <record id="fleet_document_dashboard_view_list" model="ir.ui.view">
        <field name="name">fleet.vehicle.doc.dashboard.list</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <list string="Dashboard Dokumen Kendaraan"
                  decoration-danger="doc_status == 'critical'"
                  decoration-warning="doc_status == 'warning'"
                  decoration-muted="doc_status == 'incomplete'">
                <field name="license_plate" string="Plat Nomor"/>
                <field name="name" string="Nama Kendaraan" optional="show"/>
                <field name="doc_status" widget="badge"
                       decoration-success="doc_status == 'ok'"
                       decoration-warning="doc_status == 'warning'"
                       decoration-danger="doc_status == 'critical'"
                       decoration-muted="doc_status == 'incomplete'"
                       string="Status Dokumen"/>
                <field name="document_count" string="Total Dok"/>
                <field name="expired_doc_count" string="Expired"
                       decoration-danger="expired_doc_count &gt; 0"/>
                <field name="expiring_doc_count" string="Hampir Expired"
                       decoration-warning="expiring_doc_count &gt; 0"/>
                <field name="next_expiry_date" string="Expired Terdekat"/>
                <field name="next_expiry_doc" string="Dokumen" optional="show"/>
                <button name="action_view_documents" type="object"
                        string="Lihat Dokumen" class="btn-secondary btn-sm"/>
            </list>
        </field>
    </record>

    <record id="fleet_document_dashboard_action" model="ir.actions.act_window">
        <field name="name">Dashboard Compliance Dokumen</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="fleet_document_dashboard_view_list"/>
        <field name="domain">[('active', '=', True)]</field>
        <field name="context">{'search_default_group_doc_status': 1}</field>
    </record>
</odoo>
