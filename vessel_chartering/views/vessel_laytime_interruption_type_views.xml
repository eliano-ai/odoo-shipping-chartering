<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_laytime_interruption_type_view_list" model="ir.ui.view">
        <field name="name">vessel.laytime.interruption.type.list</field>
        <field name="model">vessel.laytime.interruption.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Interupsi Laytime" editable="bottom">
                <field name="name"/>
                <field name="is_counting" string="Tetap Dihitung"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_vessel_laytime_interruption_type" model="ir.actions.act_window">
        <field name="name">Tipe Interupsi Laytime</field>
        <field name="res_model">vessel.laytime.interruption.type</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada tipe interupsi</p>
            <p>Master alasan interupsi laytime — hujan, shifting, breakdown, dll.</p>
        </field>
    </record>

</odoo>
