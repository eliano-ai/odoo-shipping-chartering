<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_voyage_pnl_list" model="ir.ui.view">
        <field name="name">vessel.voyage.pnl.list</field>
        <field name="model">vessel.voyage.pnl</field>
        <field name="arch" type="xml">
            <list decoration-danger="total_revenue - total_direct_cost &lt; 0">
                <field name="voyage_id"/>
                <field name="vessel_id"/>
                <field name="contract_id"/>
                <field name="voyage_days"/>
                <field name="total_revenue" sum="Total Revenue"/>
                <field name="total_direct_cost" sum="Total Direct Cost"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'computed'"
                       decoration-success="state == 'locked'"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_voyage_pnl_form" model="ir.ui.view">
        <field name="name">vessel.voyage.pnl.form</field>
        <field name="model">vessel.voyage.pnl</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_pnl" type="object" string="Generate P&amp;L"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_recompute" type="object" string="Recompute"
                            invisible="state not in ('draft', 'computed')"/>
                    <button name="action_lock" type="object" string="Lock"
                            class="oe_highlight" invisible="state != 'computed'"
                            groups="vessel_voyage_pnl.group_voyage_pnl_finance"/>
                    <button name="action_open_adjustment_wizard" type="object"
                            string="Adjustment Manual" invisible="state != 'locked'"
                            groups="vessel_voyage_pnl.group_voyage_pnl_finance"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_voyage"
                                class="oe_stat_button" icon="fa-ship"
                                invisible="not voyage_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Voyage</span>
                            </div>
                        </button>
                        <button type="object" name="action_view_contract"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="not contract_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Kontrak Charter</span>
                            </div>
                        </button>
                        <button type="object" name="action_view_estimate"
                                class="oe_stat_button" icon="fa-calculator"
                                invisible="not estimate_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Estimate</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="voyage_id" readonly="state != 'draft'"/>
                            <field name="contract_id" readonly="1"/>
                            <field name="vessel_id" readonly="1"/>
                            <field name="analytic_account_id" readonly="1"/>
                            <field name="estimate_id"/>
                            <field name="voyage_days" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_revenue"/>
                            <field name="total_direct_cost"/>
                            <field name="total_allocated_cost"/>
                            <field name="voyage_result"/>
                            <field name="tce_actual_per_day"/>
                            <field name="computed_date" readonly="1"/>
                            <field name="locked_by" readonly="1" invisible="not locked_by"/>
                            <field name="locked_date" readonly="1" invisible="not locked_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Revenue Detail" name="revenue_detail">
                            <group>
                                <field name="freight_revenue" readonly="1"/>
                                <field name="demurrage_revenue" readonly="1"/>
                                <field name="despatch_cost" readonly="1"/>
                                <field name="brokerage_cost" readonly="1"/>
                                <field name="other_revenue" readonly="state == 'locked'"/>
                            </group>
                            <field name="line_ids" context="{'default_pnl_id': id}"
                                   domain="[('category_group', '=', 'revenue')]">
                                <list editable="bottom" create="0">
                                    <field name="cost_category_id"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="is_manual_adjustment" optional="hide"/>
                                    <button name="action_view_source" type="object"
                                            string="Lihat Sumber" icon="fa-external-link"
                                            invisible="not source_model"/>
                                </list>
                            </field>
                        </page>
                        <page string="Direct Cost Detail" name="direct_cost_detail">
                            <group>
                                <field name="bunker_cost" readonly="1"/>
                                <field name="port_cost" readonly="1"/>
                                <field name="cargo_handling_cost" readonly="1"/>
                                <field name="insurance_voyage_cost" readonly="1"/>
                                <field name="other_direct_cost" readonly="state == 'locked'"/>
                            </group>
                            <field name="line_ids" context="{'default_pnl_id': id}"
                                   domain="[('category_group', '=', 'direct_cost')]">
                                <list editable="bottom" create="0">
                                    <field name="cost_category_id"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="is_manual_adjustment" optional="hide"/>
                                    <button name="action_view_source" type="object"
                                            string="Lihat Sumber" icon="fa-external-link"
                                            invisible="not source_model"/>
                                </list>
                            </field>
                        </page>
                        <page string="Allocated Cost Detail" name="allocated_cost_detail">
                            <group>
                                <field name="crew_cost_allocated" readonly="1"/>
                                <field name="maintenance_cost_allocated" readonly="1"/>
                                <field name="depreciation_allocated" readonly="1"/>
                                <field name="overhead_allocated" readonly="1"/>
                            </group>
                            <field name="line_ids" context="{'default_pnl_id': id}"
                                   domain="[('category_group', '=', 'allocated_cost'), ('is_manual_adjustment', '=', False)]">
                                <list create="0">
                                    <field name="cost_category_id"/>
                                    <field name="description"/>
                                    <field name="allocation_rule_id" optional="show"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Estimate vs Actual" name="estimate_vs_actual">
                            <group>
                                <group>
                                    <field name="revenue_variance"/>
                                    <field name="revenue_variance_pct" widget="percentage"/>
                                </group>
                                <group>
                                    <field name="cost_variance"/>
                                    <field name="cost_variance_pct" widget="percentage"/>
                                </group>
                            </group>
                            <group>
                                <field name="tce_variance"/>
                            </group>
                        </page>
                        <page string="Adjustment Manual" name="adjustment_manual">
                            <field name="line_ids" context="{'default_pnl_id': id}"
                                   domain="[('is_manual_adjustment', '=', True)]">
                                <list create="0">
                                    <field name="cost_category_id"/>
                                    <field name="category_group"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_vessel_voyage_pnl_search" model="ir.ui.view">
        <field name="name">vessel.voyage.pnl.search</field>
        <field name="model">vessel.voyage.pnl</field>
        <field name="arch" type="xml">
            <search>
                <field name="voyage_id"/>
                <field name="vessel_id"/>
                <field name="contract_id"/>
                <filter string="Perlu Review" name="pending_review" domain="[('state', '=', 'computed')]"/>
                <filter string="Locked" name="locked" domain="[('state', '=', 'locked')]"/>
                <filter string="Rugi" name="loss_only" domain="[('voyage_result', '&lt;', 0)]"/>
                <group>
                    <filter string="Kapal" name="group_vessel" context="{'group_by': 'vessel_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vessel_voyage_pnl" model="ir.actions.act_window">
        <field name="name">Semua Voyage P&amp;L</field>
        <field name="res_model">vessel.voyage.pnl</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_vessel_voyage_pnl_search"/>
    </record>

    <record id="action_vessel_voyage_pnl_pending_review" model="ir.actions.act_window">
        <field name="name">Perlu Review</field>
        <field name="res_model">vessel.voyage.pnl</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'computed')]</field>
        <field name="search_view_id" ref="view_vessel_voyage_pnl_search"/>
    </record>

    <record id="view_vessel_voyage_pnl_top_loss_list" model="ir.ui.view">
        <field name="name">vessel.voyage.pnl.top.loss.list</field>
        <field name="model">vessel.voyage.pnl</field>
        <field name="arch" type="xml">
            <list default_order="voyage_result asc" limit="10" create="0">
                <field name="voyage_id"/>
                <field name="vessel_id"/>
                <field name="total_revenue"/>
                <field name="total_direct_cost"/>
                <field name="total_allocated_cost"/>
                <field name="voyage_result" decoration-danger="voyage_result &lt; 0"/>
            </list>
        </field>
    </record>

    <record id="action_vessel_voyage_pnl_top_loss" model="ir.actions.act_window">
        <field name="name">Top Voyage Rugi</field>
        <field name="res_model">vessel.voyage.pnl</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '!=', 'draft')]</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_vessel_voyage_pnl_top_loss_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_vessel_voyage_pnl_form')})]"/>
        <field name="search_view_id" ref="view_vessel_voyage_pnl_search"/>
    </record>

    <record id="view_vessel_voyage_pnl_estimate_vs_actual_list" model="ir.ui.view">
        <field name="name">vessel.voyage.pnl.estimate.vs.actual.list</field>
        <field name="model">vessel.voyage.pnl</field>
        <field name="arch" type="xml">
            <list>
                <field name="voyage_id"/>
                <field name="vessel_id"/>
                <field name="estimate_id"/>
                <field name="revenue_variance"/>
                <field name="revenue_variance_pct" widget="percentage"/>
                <field name="cost_variance"/>
                <field name="cost_variance_pct" widget="percentage"/>
                <field name="tce_variance"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_voyage_pnl_estimate_vs_actual_pivot" model="ir.ui.view">
        <field name="name">vessel.voyage.pnl.estimate.vs.actual.pivot</field>
        <field name="model">vessel.voyage.pnl</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="vessel_id" type="row"/>
                <field name="revenue_variance_pct" type="measure"/>
                <field name="cost_variance_pct" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_vessel_voyage_pnl_estimate_vs_actual" model="ir.actions.act_window">
        <field name="name">Estimate vs Actual</field>
        <field name="res_model">vessel.voyage.pnl</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('estimate_id', '!=', False)]</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_vessel_voyage_pnl_estimate_vs_actual_list')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_vessel_voyage_pnl_estimate_vs_actual_pivot')})]"/>
    </record>

</odoo>
