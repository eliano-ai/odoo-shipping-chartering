<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_voyage_estimate_view_form" model="ir.ui.view">
        <field name="name">vessel.voyage.estimate.form</field>
        <field name="model">vessel.voyage.estimate</field>
        <field name="arch" type="xml">
            <form string="Voyage Estimate">
                <header>
                    <button name="action_select_baseline" type="object"
                            string="Pilih sebagai Baseline" class="btn-primary"
                            invisible="state == 'selected'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_currency_id" invisible="1"/>
                        </group>
                    </group>

                    <group string="Jarak &amp; Kecepatan">
                        <group>
                            <field name="distance_nm"/>
                            <field name="speed_knots"/>
                            <field name="sea_days"/>
                        </group>
                        <group>
                            <field name="port_days_load"/>
                            <field name="port_days_discharge"/>
                            <field name="total_voyage_days" readonly="1"/>
                        </group>
                    </group>

                    <group string="Bunker">
                        <group>
                            <field name="fo_consumption_sea"/>
                            <field name="fo_consumption_port"/>
                            <field name="fo_price_usd"/>
                        </group>
                        <group>
                            <field name="do_consumption_sea"/>
                            <field name="do_consumption_port"/>
                            <field name="do_price_usd"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="usd_rate"/>
                        </group>
                        <group>
                            <field name="bunker_cost_usd" readonly="1"/>
                            <field name="bunker_cost_idr" readonly="1"/>
                        </group>
                    </group>

                    <group string="Cost Lain">
                        <group>
                            <field name="port_cost_estimate"/>
                            <field name="other_cost_estimate"/>
                        </group>
                        <group>
                            <field name="charter_in_cost"/>
                        </group>
                    </group>

                    <group string="Hasil">
                        <group>
                            <field name="revenue_estimate" readonly="1"/>
                            <field name="total_cost_estimate" readonly="1"/>
                        </group>
                        <group>
                            <field name="voyage_result" readonly="1"/>
                            <field name="tce_per_day" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="vessel_voyage_estimate_view_list" model="ir.ui.view">
        <field name="name">vessel.voyage.estimate.list</field>
        <field name="model">vessel.voyage.estimate</field>
        <field name="arch" type="xml">
            <list string="Voyage Estimates"
                  decoration-success="state == 'selected'">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="total_voyage_days"/>
                <field name="revenue_estimate"/>
                <field name="total_cost_estimate"/>
                <field name="voyage_result"/>
                <field name="tce_per_day"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

</odoo>
