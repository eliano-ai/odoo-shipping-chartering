<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_fleet_fuel_type" model="ir.actions.act_window">
        <field name="name">Fuel Types</field>
        <field name="res_model">fleet.fuel.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_fleet_fuel_type_list" model="ir.ui.view">
        <field name="name">fleet.fuel.type.list</field>
        <field name="model">fleet.fuel.type</field>
        <field name="arch" type="xml">
            <list string="Fuel Types" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="product_id"/>
                <field name="default_price"/>
                <field name="anomaly_threshold_pct"/>
                <field name="account_id"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_fuel_type_form" model="ir.ui.view">
        <field name="name">fleet.fuel.type.form</field>
        <field name="model">fleet.fuel.type</field>
        <field name="arch" type="xml">
            <form string="Fuel Type">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Solar / HSD"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="code"/>
                            <field name="uom_id"/>
                            <field name="default_price"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                        <group string="Integration">
                            <field name="product_id" help="Produk Inventory untuk stock.move konsumsi BBM"/>
                            <field name="account_id" help="Akun beban BBM untuk journal entry"/>
                            <field name="anomaly_threshold_pct"
                                   help="Persen di atas rata-rata konsumsi yang dianggap anomali"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1" placeholder="Catatan tambahan..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
