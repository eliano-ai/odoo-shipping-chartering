<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_bunker_price_reference_list" model="ir.ui.view">
        <field name="name">vessel.bunker.price.reference.list</field>
        <field name="model">vessel.bunker.price.reference</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="date"/>
                <field name="index_name"/>
                <field name="fuel_type_id"/>
                <field name="price_usd_mt"/>
                <field name="region"/>
            </list>
        </field>
    </record>

    <record id="action_vessel_bunker_price_reference" model="ir.actions.act_window">
        <field name="name">Price Reference (MOPS/Platts)</field>
        <field name="res_model">vessel.bunker.price.reference</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
