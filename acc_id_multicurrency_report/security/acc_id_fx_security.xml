<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="group_fx_user" model="res.groups">
      <field name="name">FX Report User</field>
      <field name="privilege_id" ref="account.res_groups_privilege_accounting"/>
      <field name="implied_ids" eval="[(4, ref('account.group_account_readonly'))]"/>
      <field name="comment">
        Dapat melihat laporan dual-currency, riwayat config, dan drill-down
        transaksi. Tidak dapat membuat config baru atau menjalankan kalkulasi.
      </field>
    </record>

    <record id="group_fx_manager" model="res.groups">
      <field name="name">FX Report Manager</field>
      <field name="privilege_id" ref="account.res_groups_privilege_accounting"/>
      <field name="implied_ids" eval="[(4, ref('group_fx_user'))]"/>
      <field name="comment">
        Dapat membuat konfigurasi laporan, menjalankan kalkulasi,
        mengimport kurs BI, dan mengatur override kurs per akun.
      </field>
    </record>

    <record id="group_fx_admin" model="res.groups">
      <field name="name">FX Report Admin</field>
      <field name="privilege_id" ref="account.res_groups_privilege_accounting"/>
      <field name="implied_ids" eval="[(4, ref('group_fx_manager'))]"/>
      <field name="comment">
        Akses penuh termasuk hapus log kalkulasi.
        Hanya untuk administrator sistem — jangan assign ke user operasional.
      </field>
    </record>

  </data>
</odoo>
