<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Form ────────────────────────────────────────────────────────── -->
    <record id="vessel_port_call_view_form" model="ir.ui.view">
        <field name="name">vessel.port.call.form</field>
        <field name="model">vessel.port.call</field>
        <field name="arch" type="xml">
            <form string="Port Call">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="voyage_id" readonly="1"/>
                            —
                            <field name="port_id"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="call_purpose"/>
                            <field name="agent_id"/>
                            <field name="berth_name"/>
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="eta"/>
                            <field name="etb"/>
                            <field name="etd"/>
                        </group>
                        <group>
                            <field name="ata"/>
                            <field name="atb"/>
                            <field name="atd"/>
                        </group>
                    </group>
                    <group string="Cargo Operations">
                        <field name="cargo_ops_commenced"/>
                        <field name="cargo_ops_completed"/>
                        <field name="cargo_ops_rate_mt_day" readonly="1"/>
                    </group>
                    <group string="Clearance Checklist">
                        <field name="clearance_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="document_type_id"/>
                                <field name="direction" widget="badge"/>
                                <field name="status" widget="badge"
                                       decoration-muted="status == 'pending'"
                                       decoration-warning="status == 'submitted'"
                                       decoration-success="status == 'cleared'"
                                       decoration-danger="status == 'rejected'"/>
                                <field name="document_number"/>
                                <field name="cleared_date"/>
                            </list>
                        </field>
                    </group>
                    <group string="Disbursement (PDA/FDA)">
                        <button name="action_create_pda" type="object"
                                string="Buat PDA" class="btn-secondary"/>
                        <button name="action_create_fda" type="object"
                                string="Buat FDA" class="btn-secondary"/>
                        <field name="disbursement_ids" nolabel="1">
                            <list>
                                <field name="disbursement_type" widget="badge"/>
                                <field name="total_amount"/>
                                <field name="variance_amount"/>
                                <field name="variance_pct"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>
                    <group string="Catatan">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── List ────────────────────────────────────────────────────────── -->
    <record id="vessel_port_call_view_list" model="ir.ui.view">
        <field name="name">vessel.port.call.list</field>
        <field name="model">vessel.port.call</field>
        <field name="arch" type="xml">
            <list string="Port Calls">
                <field name="voyage_id"/>
                <field name="sequence"/>
                <field name="port_id"/>
                <field name="call_purpose"/>
                <field name="agent_id"/>
                <field name="eta"/>
                <field name="ata"/>
                <field name="atb"/>
                <field name="atd"/>
            </list>
        </field>
    </record>

    <!-- ─── Calendar ────────────────────────────────────────────────────── -->
    <record id="vessel_port_call_view_calendar" model="ir.ui.view">
        <field name="name">vessel.port.call.calendar</field>
        <field name="model">vessel.port.call</field>
        <field name="arch" type="xml">
            <calendar string="Port Call by ETA" date_start="eta" color="port_id">
                <field name="port_id"/>
                <field name="voyage_id"/>
            </calendar>
        </field>
    </record>

    <!-- ─── Search ──────────────────────────────────────────────────────── -->
    <record id="vessel_port_call_view_search" model="ir.ui.view">
        <field name="name">vessel.port.call.search</field>
        <field name="model">vessel.port.call</field>
        <field name="arch" type="xml">
            <search string="Cari Port Call">
                <field name="voyage_id"/>
                <field name="port_id"/>
                <field name="agent_id"/>
                <group>
                    <filter string="Voyage" name="group_voyage" context="{'group_by':'voyage_id'}"/>
                    <filter string="Port" name="group_port" context="{'group_by':'port_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Actions ─────────────────────────────────────────────────────── -->
    <record id="action_vessel_port_call" model="ir.actions.act_window">
        <field name="name">Port Calls</field>
        <field name="res_model">vessel.port.call</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada port call</p>
            <p>Port call dibuat dari tab Port Rotation di form voyage.</p>
        </field>
    </record>

</odoo>
