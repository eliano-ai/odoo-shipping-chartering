<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Form ────────────────────────────────────────────────────────── -->
    <record id="vessel_voyage_view_form" model="ir.ui.view">
        <field name="name">vessel.voyage.form</field>
        <field name="model">vessel.voyage</field>
        <field name="arch" type="xml">
            <form string="Voyage">
                <header>
                    <button name="action_fix" type="object"
                            string="Fixed dari Kontrak" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_depart" type="object"
                            string="Berangkat" class="btn-primary"
                            invisible="state != 'fixed'"/>
                    <button name="action_arrive_port" type="object"
                            string="Tiba di Port"
                            invisible="state != 'sailing'"/>
                    <button name="action_depart_port" type="object"
                            string="Berangkat dari Port"
                            invisible="state != 'at_port'"/>
                    <button name="action_complete" type="object"
                            string="Selesaikan Voyage" class="btn-primary"
                            invisible="state not in ('sailing', 'at_port')"/>
                    <button name="action_cancel" type="object"
                            string="Batalkan"
                            invisible="state not in ('draft', 'fixed')"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset ke Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,fixed,sailing,at_port,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="charter_contract_id"
                                   required="state != 'draft'"
                                   readonly="state != 'draft'"/>
                            <field name="vessel_id"/>
                            <field name="tug_id" invisible="not tug_id"/>
                            <field name="analytic_account_id"/>
                            <field name="fleet_trip_id"/>
                        </group>
                        <group>
                            <field name="origin_port_id"/>
                            <field name="final_port_id"/>
                            <field name="date_departure"/>
                            <field name="date_arrival_final"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="total_distance_nm"/>
                            <field name="total_delay_hours"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Port Rotation" name="port_rotation">
                            <field name="port_call_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="port_id"/>
                                    <field name="call_purpose"/>
                                    <field name="agent_id"/>
                                    <field name="eta"/>
                                    <field name="ata"/>
                                    <field name="atb"/>
                                    <field name="atd"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ─── List ────────────────────────────────────────────────────────── -->
    <record id="vessel_voyage_view_list" model="ir.ui.view">
        <field name="name">vessel.voyage.list</field>
        <field name="model">vessel.voyage</field>
        <field name="arch" type="xml">
            <list string="Voyages"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="state in ('sailing', 'at_port')">
                <field name="name"/>
                <field name="charter_contract_id"/>
                <field name="vessel_id"/>
                <field name="origin_port_id"/>
                <field name="final_port_id"/>
                <field name="date_departure"/>
                <field name="date_arrival_final"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'fixed'"
                       decoration-info="state in ('sailing', 'at_port')"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- ─── Kanban ──────────────────────────────────────────────────────── -->
    <record id="vessel_voyage_view_kanban" model="ir.ui.view">
        <field name="name">vessel.voyage.kanban</field>
        <field name="model">vessel.voyage</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div><field name="charter_contract_id"/></div>
                            <div><field name="vessel_id"/></div>
                            <div>
                                <field name="origin_port_id"/> → <field name="final_port_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Search ──────────────────────────────────────────────────────── -->
    <record id="vessel_voyage_view_search" model="ir.ui.view">
        <field name="name">vessel.voyage.search</field>
        <field name="model">vessel.voyage</field>
        <field name="arch" type="xml">
            <search string="Cari Voyage">
                <field name="name"/>
                <field name="charter_contract_id"/>
                <field name="vessel_id"/>
                <filter string="Sedang Berlayar" name="filter_sailing"
                        domain="[('state', 'in', ('sailing', 'at_port'))]"/>
                <filter string="Selesai" name="filter_completed"
                        domain="[('state', '=', 'completed')]"/>
                <group>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Kapal" name="group_vessel" context="{'group_by':'vessel_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Actions ─────────────────────────────────────────────────────── -->
    <record id="action_vessel_voyage_all" model="ir.actions.act_window">
        <field name="name">Semua Voyage</field>
        <field name="res_model">vessel.voyage</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada voyage</p>
            <p>Buat voyage dari kontrak charter yang sudah confirmed.</p>
        </field>
    </record>

    <record id="action_vessel_voyage_sailing" model="ir.actions.act_window">
        <field name="name">Sedang Berlayar</field>
        <field name="res_model">vessel.voyage</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', 'in', ('sailing', 'at_port'))]</field>
    </record>

    <record id="action_vessel_voyage_completed" model="ir.actions.act_window">
        <field name="name">Selesai</field>
        <field name="res_model">vessel.voyage</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'completed')]</field>
    </record>

</odoo>
