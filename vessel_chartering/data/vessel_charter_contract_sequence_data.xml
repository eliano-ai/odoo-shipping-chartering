    <record id="seq_vessel_charter_contract_in" model="ir.sequence">
        <field name="name">Charter Contract — In</field>
        <field name="code">vessel.charter.contract.in</field>
        <field name="prefix">CHI/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
