<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vessel_pnl_cost_category_list" model="ir.ui.view">
        <field name="name">vessel.pnl.cost.category.list</field>
        <field name="model">vessel.pnl.cost.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_group"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_vessel_pnl_cost_category_form" model="ir.ui.view">
        <field name="name">vessel.pnl.cost.category.form</field>
        <field name="model">vessel.pnl.cost.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category_group"/>
                        <field name="sequence"/>
                        <field name="default_account_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vessel_pnl_cost_category" model="ir.actions.act_window">
        <field name="name">Kategori Biaya P&amp;L</field>
        <field name="res_model">vessel.pnl.cost.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
