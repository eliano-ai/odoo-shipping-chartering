<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_chartering_user" model="res.groups">
        <field name="name">Chartering Operations</field>
        <field name="implied_ids" eval="[(4, ref('fleet.fleet_group_user'))]"/>
    </record>

    <record id="group_chartering_manager" model="res.groups">
        <field name="name">Chartering Manager</field>
        <field name="implied_ids" eval="[(4, ref('vessel_chartering.group_chartering_user')), (4, ref('fleet.fleet_group_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- ─── Record Rules — Multi-Company ───────────────────────────────── -->
    <record id="rule_vessel_charter_contract_company" model="ir.rule">
        <field name="name">Charter Contract: multi-company</field>
        <field name="model_id" ref="model_vessel_charter_contract"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_vessel_laytime_calculation_company" model="ir.rule">
        <field name="name">Laytime Calculation: multi-company</field>
        <field name="model_id" ref="model_vessel_laytime_calculation"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
