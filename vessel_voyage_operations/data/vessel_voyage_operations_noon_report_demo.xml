<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Noon report untuk demo_voyage_2 (time charter, sailing) — mayoritas approved,
         1 rejected + 1 re-submit sebagai contoh histori tidak hilang. -->
    <record id="demo_noon_report_1" model="vessel.noon.report">
        <field name="voyage_id" ref="demo_voyage_2"/>
        <field name="report_datetime" eval="(datetime.today() - timedelta(days=4)).strftime('%Y-%m-%d 12:00:00')"/>
        <field name="report_type">noon_at_sea</field>
        <field name="latitude">-6.104</field>
        <field name="longitude">106.887</field>
        <field name="speed_knots">11.5</field>
        <field name="distance_run_nm">220.0</field>
        <field name="rob_fo">85.0</field>
        <field name="rob_do">22.0</field>
        <field name="state">approved</field>
    </record>

    <record id="demo_noon_report_2" model="vessel.noon.report">
        <field name="voyage_id" ref="demo_voyage_2"/>
        <field name="report_datetime" eval="(datetime.today() - timedelta(days=3)).strftime('%Y-%m-%d 12:00:00')"/>
        <field name="report_type">noon_at_sea</field>
        <field name="latitude">-4.5</field>
        <field name="longitude">107.9</field>
        <field name="speed_knots">11.2</field>
        <field name="distance_run_nm">215.0</field>
        <field name="rob_fo">78.0</field>
        <field name="rob_do">20.5</field>
        <field name="state">approved</field>
    </record>

    <record id="demo_noon_report_3" model="vessel.noon.report">
        <field name="voyage_id" ref="demo_voyage_2"/>
        <field name="report_datetime" eval="(datetime.today() - timedelta(days=2)).strftime('%Y-%m-%d 12:00:00')"/>
        <field name="report_type">noon_at_sea</field>
        <field name="latitude">-2.9</field>
        <field name="longitude">108.7</field>
        <field name="speed_knots">10.8</field>
        <field name="distance_run_nm">205.0</field>
        <field name="rob_fo">71.0</field>
        <field name="rob_do">19.0</field>
        <field name="state">approved</field>
    </record>

    <record id="demo_noon_report_4_rejected" model="vessel.noon.report">
        <field name="voyage_id" ref="demo_voyage_2"/>
        <field name="report_datetime" eval="(datetime.today() - timedelta(days=1)).strftime('%Y-%m-%d 09:00:00')"/>
        <field name="report_type">noon_at_sea</field>
        <field name="latitude">-1.2</field>
        <field name="longitude">109.5</field>
        <field name="distance_run_nm">340.0</field>
        <field name="state">rejected</field>
        <field name="rejection_reason">Distance run 340 NM tidak masuk akal untuk speed rata-rata kapal ini — kemungkinan salah input.</field>
    </record>

    <record id="demo_noon_report_5_resubmit" model="vessel.noon.report">
        <field name="voyage_id" ref="demo_voyage_2"/>
        <field name="report_datetime" eval="(datetime.today() - timedelta(days=1)).strftime('%Y-%m-%d 14:00:00')"/>
        <field name="report_type">noon_at_sea</field>
        <field name="latitude">-1.2</field>
        <field name="longitude">109.5</field>
        <field name="speed_knots">10.9</field>
        <field name="distance_run_nm">208.0</field>
        <field name="rob_fo">64.0</field>
        <field name="rob_do">17.5</field>
        <field name="state">approved</field>
    </record>

</odoo>
