<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shopify_bulk_sync_wizard" model="ir.ui.view">
        <field name="name">shopify.bulk.sync.wizard.form</field>
        <field name="model">shopify.bulk.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Sync">
                <group>
                    <field name="config_id"/>
                    <field name="sync_products"/>
                    <field name="sync_inventory"/>
                    <!-- Odoo 19: attrs replaced with inline invisible -->
                    <field name="sync_orders_since"
                           invisible="not sync_orders_since"/>
                </group>
                <footer>
                    <button name="action_run_sync" string="Run Sync"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
