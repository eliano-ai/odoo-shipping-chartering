<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="vessel_clearance_document_type_view_list" model="ir.ui.view">
        <field name="name">vessel.clearance.document.type.list</field>
        <field name="model">vessel.clearance.document.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Dokumen Clearance" editable="bottom">
                <field name="name"/>
                <field name="default_required"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="vessel_clearance_document_type_view_form" model="ir.ui.view">
        <field name="name">vessel.clearance.document.type.form</field>
        <field name="model">vessel.clearance.document.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Dokumen Clearance">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="default_required"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vessel_clearance_document_type" model="ir.actions.act_window">
        <field name="name">Tipe Dokumen Clearance</field>
        <field name="res_model">vessel.clearance.document.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Belum ada tipe dokumen clearance</p>
            <p>Buat master dokumen clearance pelabuhan — SPB, Imigrasi, Karantina, Bea Cukai, dll.</p>
        </field>
    </record>

</odoo>
