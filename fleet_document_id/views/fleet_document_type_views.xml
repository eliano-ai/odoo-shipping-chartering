<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── fleet.document.vessel.type — List & Form ───────────────────── -->
    <record id="fleet_document_vessel_type_view_list" model="ir.ui.view">
        <field name="name">fleet.document.vessel.type.list</field>
        <field name="model">fleet.document.vessel.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Kapal" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="vehicle_count" string="Jumlah Kapal"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="fleet_document_vessel_type_view_form" model="ir.ui.view">
        <field name="name">fleet.document.vessel.type.form</field>
        <field name="model">fleet.document.vessel.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Kapal">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_vehicles" type="object"
                                class="oe_stat_button" icon="fa-ship"
                                invisible="vehicle_count == 0">
                            <field name="vehicle_count" widget="statinfo" string="Kapal"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Keterangan tipe kapal..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_document_vessel_type" model="ir.actions.act_window">
        <field name="name">Tipe Kapal</field>
        <field name="res_model">fleet.document.vessel.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ─── fleet.document.type — List ─────────────────────────────────── -->
    <record id="fleet_document_type_view_list" model="ir.ui.view">
        <field name="name">fleet.document.type.list</field>
        <field name="model">fleet.document.type</field>
        <field name="arch" type="xml">
            <list string="Tipe Dokumen" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category" widget="badge"
                       decoration-info="category == 'land'"
                       decoration-success="category == 'vessel'"
                       decoration-warning="category == 'both'"/>
                <field name="requires_crew" optional="show"/>
                <field name="requires_driver" optional="show"/>
                <field name="default_alert_days" string="Alert (hari)" optional="show"/>
                <field name="has_survey_interval" optional="show"/>
                <field name="document_count" string="Dokumen"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ─── fleet.document.type — Form ─────────────────────────────────── -->
    <record id="fleet_document_type_view_form" model="ir.ui.view">
        <field name="name">fleet.document.type.form</field>
        <field name="model">fleet.document.type</field>
        <field name="arch" type="xml">
            <form string="Tipe Dokumen">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="document_count == 0">
                            <field name="document_count" widget="statinfo" string="Dokumen"/>
                        </button>
                    </div>
                    <group>
                        <group string="Identitas">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Kategori &amp; Kepemilikan">
                            <field name="category" widget="radio"/>
                            <field name="requires_driver"
                                   invisible="category == 'vessel'"/>
                            <field name="requires_crew"
                                   invisible="category == 'land'"/>
                        </group>
                    </group>

                    <group string="Berlaku untuk Tipe Kapal"
                           invisible="category == 'land'">
                        <field name="applicable_vessel_types"
                               widget="many2many_tags"
                               string="Tipe Kapal"
                               help="Kosongkan jika berlaku untuk semua tipe kapal"/>
                    </group>

                    <group string="Konfigurasi Alert &amp; Survey">
                        <group>
                            <field name="default_alert_days"/>
                        </group>
                        <group>
                            <field name="has_survey_interval"
                                   invisible="category == 'land'"/>
                            <field name="survey_interval_months"
                                   invisible="not has_survey_interval or category == 'land'"/>
                        </group>
                    </group>

                    <field name="description" placeholder="Keterangan dokumen, dasar hukum, instansi penerbit, dll..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Search ──────────────────────────────────────────────────────── -->
    <record id="fleet_document_type_view_search" model="ir.ui.view">
        <field name="name">fleet.document.type.search</field>
        <field name="model">fleet.document.type</field>
        <field name="arch" type="xml">
            <search string="Cari Tipe Dokumen">
                <field name="name"/>
                <field name="code"/>
                <filter string="Kendaraan Darat" name="filter_land"
                        domain="[('category', 'in', ['land', 'both'])]"/>
                <filter string="Kapal Laut" name="filter_vessel"
                        domain="[('category', 'in', ['vessel', 'both'])]"/>
                <separator/>
                <filter string="Terkait Crew" name="filter_crew"
                        domain="[('requires_crew', '=', True)]"/>
                <filter string="Ada Survey Antara" name="filter_survey"
                        domain="[('has_survey_interval', '=', True)]"/>
               
            </search>
        </field>
    </record>

    <!-- ─── Action ──────────────────────────────────────────────────────── -->
    <record id="action_fleet_document_type" model="ir.actions.act_window">
        <field name="name">Master Tipe Dokumen</field>
        <field name="res_model">fleet.document.type</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_land': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada tipe dokumen
            </p>
            <p>
                Buat master tipe dokumen untuk kendaraan darat (STNK, SIM, KIR)
                dan kapal laut (BKI, Sijil, SPB, STCW, dll).
            </p>
        </field>
    </record>

</odoo>
