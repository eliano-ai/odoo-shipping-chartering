<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sync Pending Inventory — every 15 minutes -->
        <record id="cron_sync_inventory" model="ir.cron">
            <field name="name">Shopify: Sync Pending Inventory</field>
            <field name="model_id" ref="model_shopify_inventory_sync"/>
            <field name="state">code</field>
            <field name="code">
configs = env['shopify.config'].search([('is_active', '=', True), ('sync_inventory', '=', True)])
for config in configs:
    env['shopify.inventory.sync'].bulk_sync_inventory(config)
            </field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Pull New Orders (polling fallback) — every 15 minutes -->
        <record id="cron_pull_orders" model="ir.cron">
            <field name="name">Shopify: Pull New Orders (Fallback)</field>
            <field name="model_id" ref="model_shopify_order_sync"/>
            <field name="state">code</field>
            <field name="code">
configs = env['shopify.config'].search([('is_active', '=', True), ('sync_order', '=', True)])
for config in configs:
    env['shopify.order.sync'].poll_new_orders(config)
            </field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Sync Product Updates — every 1 hour -->
        <record id="cron_sync_products" model="ir.cron">
            <field name="name">Shopify: Sync Product Updates</field>
            <field name="model_id" ref="model_shopify_product_sync"/>
            <field name="state">code</field>
            <field name="code">
configs = env['shopify.config'].search([('is_active', '=', True), ('sync_product', '=', True)])
for config in configs:
    env['shopify.product.sync'].bulk_sync_products(config)
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- Verify Webhooks — daily -->
        <record id="cron_verify_webhooks" model="ir.cron">
            <field name="name">Shopify: Verify Webhook Registrations</field>
            <field name="model_id" ref="model_shopify_webhook_manager"/>
            <field name="state">code</field>
            <field name="code">
configs = env['shopify.config'].search([('is_active', '=', True)])
for config in configs:
    env['shopify.webhook.manager'].verify_all_webhooks(config)
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Inventory Reconciliation — daily -->
        <record id="cron_reconcile_inventory" model="ir.cron">
            <field name="name">Shopify: Inventory Reconciliation</field>
            <field name="model_id" ref="model_shopify_inventory_sync"/>
            <field name="state">code</field>
            <field name="code">
configs = env['shopify.config'].search([('is_active', '=', True), ('sync_inventory', '=', True)])
for config in configs:
    env['shopify.inventory.sync'].reconcile_inventory(config)
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <!-- Cleanup Old Logs — weekly -->
        <record id="cron_cleanup_logs" model="ir.cron">
            <field name="name">Shopify: Cleanup Old Logs</field>
            <field name="model_id" ref="model_shopify_sync_log"/>
            <field name="state">code</field>
            <field name="code">env['shopify.sync.log'].cleanup_old_logs()</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>