<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ── Per-vehicle report ─────────────────────────────────────────────── -->
<template id="report_fleet_doc_compliance">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="vehicle">
            <t t-call="web.external_layout">
                <div class="page">
                    <style>
                        .doc-header { background: #1F4E79; color: white; padding: 12px 16px; border-radius: 6px; margin-bottom: 16px; }
                        .doc-header h2 { margin: 0; font-size: 18px; }
                        .doc-header p  { margin: 2px 0 0; opacity: 0.8; font-size: 13px; }
                        .meta-row { display: flex; gap: 24px; margin-bottom: 16px; }
                        .meta-item { font-size: 12px; }
                        .meta-label { color: #666; }
                        .meta-value { font-weight: bold; color: #1F4E79; }
                        table.doc-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 8px; }
                        .doc-table th { background: #D6E4F0; color: #1F4E79; padding: 7px 10px; text-align: left; font-weight: bold; border: 1px solid #BDD3E8; }
                        .doc-table td { padding: 6px 10px; border: 1px solid #e0e0e0; vertical-align: middle; }
                        .doc-table tr:nth-child(even) td { background: #f8f9fa; }
                        .badge-valid    { background: #d4edda; color: #155724; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: bold; }
                        .badge-warning  { background: #fff3cd; color: #856404; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: bold; }
                        .badge-expired  { background: #f8d7da; color: #721c24; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: bold; }
                        .badge-missing  { background: #e2e3e5; color: #383d41; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: bold; }
                        .summary-box { border: 1px solid #dee2e6; border-radius: 6px; padding: 10px 14px; margin-bottom: 16px; }
                        .summary-grid { display: flex; gap: 20px; }
                        .summary-cell { text-align: center; }
                        .summary-num  { font-size: 22px; font-weight: bold; }
                        .summary-lbl  { font-size: 11px; color: #666; }
                        .text-danger  { color: #dc3545; }
                        .text-warning { color: #e67e22; }
                        .text-success { color: #28a745; }
                    </style>

                    <div class="doc-header">
                        <h2>Laporan Dokumen Legal Kendaraan</h2>
                        <p><t t-esc="vehicle.license_plate or ''"/> — <t t-esc="vehicle.name or ''"/></p>
                    </div>

                    <div class="meta-row">
                        <div class="meta-item">
                            <div class="meta-label">Tanggal Cetak</div>
                            <div class="meta-value"><t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/></div>
                        </div>
                        <div class="meta-item">
                            <div class="meta-label">Perusahaan</div>
                            <div class="meta-value"><t t-esc="vehicle.company_id.name or ''"/></div>
                        </div>
                        <div class="meta-item">
                            <div class="meta-label">Status Keseluruhan</div>
                            <div class="meta-value">
                                <t t-if="vehicle.doc_status == 'ok'"><span class="badge-valid">Semua Valid</span></t>
                                <t t-elif="vehicle.doc_status == 'warning'"><span class="badge-warning">Ada Hampir Expired</span></t>
                                <t t-elif="vehicle.doc_status == 'critical'"><span class="badge-expired">Ada yang Expired</span></t>
                                <t t-else=""><span class="badge-missing">Tidak Lengkap</span></t>
                            </div>
                        </div>
                    </div>

                    <div class="summary-box">
                        <div class="summary-grid">
                            <div class="summary-cell">
                                <div class="summary-num"><t t-esc="vehicle.document_count"/></div>
                                <div class="summary-lbl">Total Dokumen</div>
                            </div>
                            <div class="summary-cell">
                                <div class="summary-num text-danger"><t t-esc="vehicle.expired_doc_count"/></div>
                                <div class="summary-lbl">Expired</div>
                            </div>
                            <div class="summary-cell">
                                <div class="summary-num text-warning"><t t-esc="vehicle.expiring_doc_count"/></div>
                                <div class="summary-lbl">Hampir Expired</div>
                            </div>
                        </div>
                    </div>

                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>Jenis Dokumen</th>
                                <th>Nomor Dokumen</th>
                                <th>Pengemudi / Instansi</th>
                                <th>Berlaku Hingga</th>
                                <th style="text-align:center;">Sisa Hari</th>
                                <th style="text-align:center;">Status</th>
                                <th>PIC Perpanjangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="vehicle.document_ids.filtered(lambda d: d.active)" t-as="doc">
                                <tr>
                                    <td><t t-esc="dict(doc._fields['doc_type'].selection).get(doc.doc_type, doc.doc_type)"/></td>
                                    <td><t t-esc="doc.doc_number or '—'"/></td>
                                    <td>
                                        <t t-if="doc.doc_type == 'sim'"><t t-esc="doc.driver_id.name or '—'"/></t>
                                        <t t-else=""><t t-esc="doc.issuing_authority or '—'"/></t>
                                    </td>
                                    <td><t t-esc="doc.expiry_date.strftime('%d/%m/%Y') if doc.expiry_date else '—'"/></td>
                                    <td style="text-align:center;">
                                        <t t-if="doc.days_remaining &lt; 0">
                                            <span class="text-danger"><t t-esc="doc.days_remaining"/></span>
                                        </t>
                                        <t t-elif="doc.days_remaining &lt;= 30">
                                            <span class="text-warning"><t t-esc="doc.days_remaining"/></span>
                                        </t>
                                        <t t-else=""><t t-esc="doc.days_remaining"/></t>
                                    </td>
                                    <td style="text-align:center;">
                                        <t t-if="doc.state == 'valid'"><span class="badge-valid">Valid</span></t>
                                        <t t-elif="doc.state == 'expiring_soon'"><span class="badge-warning">Hampir Expired</span></t>
                                        <t t-elif="doc.state == 'expired'"><span class="badge-expired">Expired</span></t>
                                        <t t-else=""><span class="badge-missing">—</span></t>
                                    </td>
                                    <td><t t-esc="doc.renewal_pic_id.name or '—'"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <t t-set="logs" t-value="vehicle.document_ids.mapped('renewal_log_ids').sorted('renewal_date', reverse=True)[:10]"/>
                    <t t-if="logs">
                        <h4 style="margin-top:20px; color:#1F4E79;">Riwayat Perpanjangan Terkini (10 Terakhir)</h4>
                        <table class="doc-table">
                            <thead>
                                <tr>
                                    <th>Tanggal</th>
                                    <th>Dokumen</th>
                                    <th>Expired Lama</th>
                                    <th>Expired Baru</th>
                                    <th>Biaya (IDR)</th>
                                    <th>Diproses Oleh</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="logs" t-as="log">
                                    <tr>
                                        <td><t t-esc="log.renewal_date.strftime('%d/%m/%Y') if log.renewal_date else '—'"/></td>
                                        <td><t t-esc="log.document_id.display_name or '—'"/></td>
                                        <td><t t-esc="log.previous_expiry_date.strftime('%d/%m/%Y') if log.previous_expiry_date else '—'"/></td>
                                        <td><t t-esc="log.new_expiry_date.strftime('%d/%m/%Y') if log.new_expiry_date else '—'"/></td>
                                        <td><t t-esc="'{:,.0f}'.format(log.cost) if log.cost else '—'"/></td>
                                        <td><t t-esc="log.renewed_by.name or '—'"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </t>
    </t>
</template>

<!-- ── Summary report — all vehicles ────────────────────────────────────── -->
<template id="report_fleet_doc_summary">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
            <div class="page">
                <style>
                    .doc-header { background: #1F4E79; color: white; padding: 14px 18px; border-radius: 6px; margin-bottom: 20px; }
                    .doc-header h2 { margin: 0; font-size: 20px; }
                    .doc-header p  { margin: 3px 0 0; opacity: 0.8; font-size: 13px; }
                    .kpi-row { display: flex; gap: 12px; margin-bottom: 20px; }
                    .kpi-box { flex: 1; border: 1px solid #dee2e6; border-radius: 6px; padding: 12px; text-align: center; }
                    .kpi-num  { font-size: 28px; font-weight: bold; }
                    .kpi-lbl  { font-size: 11px; color: #666; margin-top: 2px; }
                    table.doc-table { width: 100%; border-collapse: collapse; font-size: 11px; }
                    .doc-table th { background: #D6E4F0; color: #1F4E79; padding: 6px 8px; text-align: left; border: 1px solid #BDD3E8; }
                    .doc-table td { padding: 5px 8px; border: 1px solid #e0e0e0; }
                    .doc-table tr:nth-child(even) td { background: #f8f9fa; }
                    .badge-valid   { background: #d4edda; color: #155724; padding: 1px 7px; border-radius: 8px; font-size: 10px; font-weight: bold; }
                    .badge-warning { background: #fff3cd; color: #856404; padding: 1px 7px; border-radius: 8px; font-size: 10px; font-weight: bold; }
                    .badge-expired { background: #f8d7da; color: #721c24; padding: 1px 7px; border-radius: 8px; font-size: 10px; font-weight: bold; }
                    .text-danger   { color: #dc3545; font-weight: bold; }
                    .text-warning  { color: #e67e22; font-weight: bold; }
                </style>

                <div class="doc-header">
                    <h2>Fleet Compliance Summary — Dokumen Legal Kendaraan</h2>
                    <p>Dicetak: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %B %Y, %H:%M WIB')"/></p>
                </div>

                <t t-set="all_expired"  t-value="docs.filtered(lambda d: d.state == 'expired')"/>
                <t t-set="all_expiring" t-value="docs.filtered(lambda d: d.state == 'expiring_soon')"/>
                <t t-set="all_valid"    t-value="docs.filtered(lambda d: d.state == 'valid')"/>

                <div class="kpi-row">
                    <div class="kpi-box">
                        <div class="kpi-num"><t t-esc="len(docs)"/></div>
                        <div class="kpi-lbl">Total Dokumen</div>
                    </div>
                    <div class="kpi-box" style="border-color:#f8d7da;">
                        <div class="kpi-num text-danger"><t t-esc="len(all_expired)"/></div>
                        <div class="kpi-lbl">Expired</div>
                    </div>
                    <div class="kpi-box" style="border-color:#fff3cd;">
                        <div class="kpi-num text-warning"><t t-esc="len(all_expiring)"/></div>
                        <div class="kpi-lbl">Hampir Expired</div>
                    </div>
                    <div class="kpi-box" style="border-color:#d4edda;">
                        <div class="kpi-num" style="color:#28a745;"><t t-esc="len(all_valid)"/></div>
                        <div class="kpi-lbl">Valid</div>
                    </div>
                </div>

                <t t-if="all_expired">
                    <h4 style="color:#721c24; margin:16px 0 8px;">Dokumen Expired</h4>
                    <table class="doc-table">
                        <thead><tr>
                            <th>Kendaraan</th><th>Jenis</th><th>Nomor</th>
                            <th>Expired Pada</th><th style="text-align:center;">Lewat (Hari)</th><th>PIC</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="all_expired.sorted('expiry_date')" t-as="doc">
                                <tr>
                                    <td><t t-esc="doc.vehicle_id.license_plate or doc.vehicle_id.name or '—'"/></td>
                                    <td><t t-esc="dict(doc._fields['doc_type'].selection).get(doc.doc_type, doc.doc_type)"/></td>
                                    <td><t t-esc="doc.doc_number or '—'"/></td>
                                    <td><t t-esc="doc.expiry_date.strftime('%d/%m/%Y') if doc.expiry_date else '—'"/></td>
                                    <td style="text-align:center;" class="text-danger"><t t-esc="abs(doc.days_remaining)"/></td>
                                    <td><t t-esc="doc.renewal_pic_id.name or '—'"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <t t-if="all_expiring">
                    <h4 style="color:#856404; margin:20px 0 8px;">Dokumen Hampir Expired (dalam 30 hari)</h4>
                    <table class="doc-table">
                        <thead><tr>
                            <th>Kendaraan</th><th>Jenis</th><th>Nomor</th>
                            <th>Berlaku Hingga</th><th style="text-align:center;">Sisa Hari</th><th>PIC</th>
                        </tr></thead>
                        <tbody>
                            <t t-foreach="all_expiring.sorted('expiry_date')" t-as="doc">
                                <tr>
                                    <td><t t-esc="doc.vehicle_id.license_plate or doc.vehicle_id.name or '—'"/></td>
                                    <td><t t-esc="dict(doc._fields['doc_type'].selection).get(doc.doc_type, doc.doc_type)"/></td>
                                    <td><t t-esc="doc.doc_number or '—'"/></td>
                                    <td><t t-esc="doc.expiry_date.strftime('%d/%m/%Y') if doc.expiry_date else '—'"/></td>
                                    <td style="text-align:center;" class="text-warning"><t t-esc="doc.days_remaining"/></td>
                                    <td><t t-esc="doc.renewal_pic_id.name or '—'"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </div>
        </t>
    </t>
</template>

</odoo>
